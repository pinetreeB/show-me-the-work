{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{FABLE_LITE_ROOT}/adapters/codex_cli/user_prompt_submit.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python '{FABLE_LITE_ROOT}/adapters/codex_cli/user_prompt_submit.py'\"",
            "timeout": 10,
            "statusMessage": "smtw prompt routing"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|apply_patch|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{FABLE_LITE_ROOT}/adapters/codex_cli/pre_tool_use.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python '{FABLE_LITE_ROOT}/adapters/codex_cli/pre_tool_use.py'\"",
            "timeout": 10,
            "statusMessage": "smtw pre-tool gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|apply_patch|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{FABLE_LITE_ROOT}/adapters/codex_cli/post_tool_use.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python '{FABLE_LITE_ROOT}/adapters/codex_cli/post_tool_use.py'\"",
            "timeout": 10,
            "statusMessage": "smtw post-tool ledger"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"{FABLE_LITE_ROOT}/adapters/codex_cli/stop.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python '{FABLE_LITE_ROOT}/adapters/codex_cli/stop.py'\"",
            "timeout": 10,
            "statusMessage": "smtw stop gate"
          }
        ]
      }
    ]
  }
}
