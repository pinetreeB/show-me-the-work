{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"adapters/codex_cli/user_prompt_submit.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python (Join-Path (Get-Location).Path 'adapters/codex_cli/user_prompt_submit.py')\"",
            "timeout": 10,
            "statusMessage": "fable-lite prompt routing"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell|apply_patch|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"adapters/codex_cli/pre_tool_use.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python (Join-Path (Get-Location).Path 'adapters/codex_cli/pre_tool_use.py')\"",
            "timeout": 10,
            "statusMessage": "fable-lite pre-tool gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|PowerShell|apply_patch|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"adapters/codex_cli/post_tool_use.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python (Join-Path (Get-Location).Path 'adapters/codex_cli/post_tool_use.py')\"",
            "timeout": 10,
            "statusMessage": "fable-lite post-tool ledger"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"adapters/codex_cli/stop.py\"",
            "commandWindows": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"python (Join-Path (Get-Location).Path 'adapters/codex_cli/stop.py')\"",
            "timeout": 10,
            "statusMessage": "fable-lite stop gate"
          }
        ]
      }
    ]
  }
}
